   "source": [
    "def sumOfDigits(n):\n",
    "    n = abs(n)\n",
    "    if n == 0:\n",
    "        return 0\n",
    "\n",
    "    return (n % 10) + sumOfDigits(n // 10)\n",
    "\n",
    "angka = int(input(\"Masukkan angka: \"))\n",
    "hasil = sumOfDigits(angka)\n",
    "print(\"Jumlah digit:\", hasil)"
   ]
  },
