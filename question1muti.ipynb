    "        sum += i\n",
    "    for i in array:\n",
    "        product *= i\n",
    "    print(\"Sum = \"+str(sum)+\", Product = \"+str(product))\n",
    "\n",
    "ar1 = [1,2,3,4]\n",
    "foo(ar1)"
