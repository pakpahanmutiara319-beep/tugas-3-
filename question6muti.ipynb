   "source": [
    "def reverse(array):\n",
    "    for i in range(0, int(len(array)/2)):\n",
    "        other = len(array) - i - 1\n",
    "        temp = array[i]\n",
    "        array[i] = array[other]\n",
    "        array[other] = temp\n",
    "    print(array)\n",
    "arrayA = [1, 2, 3, 4, 5]\n",
    "\n",
    "reverse(arrayA)"
   ]
