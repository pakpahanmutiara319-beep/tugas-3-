   "source": [
    "def allFib(n):\n",
    "    for i in range(n):\n",
    "        print(str(i)+\":, \" + str(fib(i)))\n",
    "\n",
    "def fib(n):\n",
    "    if n <= 0:\n",
    "        return 0\n",
    "    elif n == 1:\n",
    "        return 1\n",
    "    return fib(n-1) + fib(n-2)\n",
    "\n",
    "\n",
    "allFib(4)"
   ]
