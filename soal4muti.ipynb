     "text": [
      "Masukkan bilangan desimal:  12\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Biner dari 12 adalah: 1100\n"
     ]
    }
   ],
   "source": [
    "def decimal_to_binary(n):\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    else:\n",
    "        return (n % 2) + 10 * decimal_to_binary(n // 2)\n",
    "\n",
    "angka = int(input(\"Masukkan bilangan desimal: \"))\n",
    "hasil = decimal_to_binary(angka)\n",
    "\n",
    "print(\"Biner dari\", angka, \"adalah:\", hasil)"
   ]
  },
