   "source": [
    "def printPairs(array):\n",
    "    for i in range(len(array)):\n",
    "        for j in range(i + 1, len(array)):\n",
    "            print(f\"{array[i]},{array[j]}\")\n",
    "\n",
    "printPairs([1, 2, 3])"
   ]
