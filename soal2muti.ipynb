   "source": [
    "def power(x, n):\n",
    "    if n == 0:\n",
    "        return 1\n",
    "    return x * power(x, n - 1)\n",
    "\n",
    "x = int(input(\"Masukkan nilai x: \"))\n",
    "n = int(input(\"Masukkan pangkat n: \"))\n",
    "\n",
    "hasil = power(x, n)\n",
    "print(\"Hasil:\", hasil)"
   ]
