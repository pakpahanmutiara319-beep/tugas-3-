   "source": [
    "def printUnorderedPairs(array):\n",
    "    for i in range(0, len(array)):\n",
    "        for j in range(i + 1, len(array)):\n",
    "            print(str(array[i]) + \",\" + str(array[j]))\n",
    "\n",
    "printUnorderedPairs([1, 2, 3])"
   ]
  }
 ],
